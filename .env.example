PLATFORM_DOMAIN=localhost
PLATFORM_BASE_URL=http://os7.localhost
PROJECT_PUBLIC_SCHEME=http
OAUTH_INTERNAL_BASE_URL=http://os7_traefik
COMPOSE_PROJECT_NAME=os7
STACK_NAME=os7

MANAGER_PORT=8080
FORGEJO_HTTP_PORT=8081
POSTGRES_PORT=8082
REDIS_PORT=8084
FORGEJO_SSH_PORT=8085
