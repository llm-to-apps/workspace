PLATFORM_DOMAIN=localhost
PLATFORM_BASE_URL=http://os7.localhost
PROJECT_PUBLIC_SCHEME=http
OAUTH_INTERNAL_BASE_URL=http://os7_traefik
COMPOSE_PROJECT_NAME=os7
STACK_NAME=os7

MANAGER_PORT=8080
FORGEJO_HTTP_PORT=8081
POSTGRES_PORT=8082
REDIS_PORT=8084
FORGEJO_SSH_PORT=8085
APP_READY_BASE_URL=http://127.0.0.1
DEPLOY_APP_READY_TIMEOUT_MS=900000

MANAGER_IMAGE=os7-manager
MANAGER_IMAGE_TAG=local
TRAEFIK_IMAGE=traefik:v3.7
MYSQL_IMAGE=mysql:8.4
POSTGRES_IMAGE=postgres:17-alpine
REDIS_IMAGE=redis:7.4-alpine

MYSQL_HOST=mysql
MYSQL_ROOT_USER=root
MYSQL_ROOT_PASSWORD=change-me-root-password

POSTGRES_USER=os7
POSTGRES_PASSWORD=change-me-platform-password
POSTGRES_DATABASE=os7_platform

FORGEJO_IMAGE=codeberg.org/forgejo/forgejo:15
FORGEJO_ROOT_URL=http://localhost:8081/
FORGEJO_SSH_DOMAIN=localhost
FORGEJO_URL=http://localhost:8081
FORGEJO_GIT_URL=http://forgejo
FORGEJO_POSTGRES_DATABASE=forgejo
FORGEJO_POSTGRES_USER=forgejo
FORGEJO_POSTGRES_PASSWORD=forgejo
FORGEJO_SECRET_KEY=dev-forgejo-secret-key-change-me
FORGEJO_INTERNAL_TOKEN=dev-forgejo-internal-token-change-me
FORGEJO_DISABLE_REGISTRATION=true
FORGEJO_ADMIN_USER=root
FORGEJO_ADMIN_PASSWORD=admin1234
FORGEJO_ADMIN_EMAIL=root@example.local

USER_INSTANCE_IMAGE=os7/user-instance:latest
