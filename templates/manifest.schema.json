{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://os7.local/schemas/template-manifest.schema.json",
  "title": "OS7 template manifest",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "id",
    "slug",
    "name",
    "description",
    "icon",
    "status",
    "source",
    "git",
    "runtime",
    "services",
    "env"
  ],
  "properties": {
    "$schema": {
      "type": "string"
    },
    "schemaVersion": {
      "type": "integer",
      "const": 1
    },
    "id": {
      "type": "string",
      "pattern": "^[A-Za-z][A-Za-z0-9_-]{1,63}$"
    },
    "slug": {
      "type": "string",
      "pattern": "^[a-z0-9][a-z0-9-]{0,62}$"
    },
    "name": {
      "type": "string",
      "minLength": 1,
      "maxLength": 128
    },
    "description": {
      "type": "string",
      "minLength": 1
    },
    "icon": {
      "type": "string",
      "minLength": 1,
      "maxLength": 64
    },
    "status": {
      "type": "string",
      "enum": ["available", "coming_soon"]
    },
    "sortOrder": {
      "type": "integer",
      "minimum": 0
    },
    "source": {
      "type": "object",
      "additionalProperties": false,
      "required": ["repository", "remote"],
      "properties": {
        "repository": {
          "type": "string",
          "minLength": 1,
          "maxLength": 128
        },
        "remote": {
          "type": "string",
          "minLength": 1
        },
        "path": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "updates": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "github": {
          "type": "object",
          "additionalProperties": false,
          "required": ["repository", "ref", "path"],
          "properties": {
            "repository": {
              "type": "string",
              "pattern": "^[A-Za-z0-9_.-]+/[A-Za-z0-9_.-]+$"
            },
            "ref": {
              "type": "string",
              "minLength": 1
            },
            "path": {
              "type": "string",
              "minLength": 1
            }
          }
        }
      }
    },
    "git": {
      "type": "object",
      "additionalProperties": false,
      "required": ["mount"],
      "properties": {
        "mount": {
          "type": "object",
          "additionalProperties": false,
          "required": ["target", "strategy"],
          "properties": {
            "target": {
              "type": "string",
              "pattern": "^/"
            },
            "strategy": {
              "type": "string",
              "enum": ["clone", "copy-template"]
            },
            "defaultBranch": {
              "type": "string",
              "minLength": 1
            },
            "preserve": {
              "type": "array",
              "items": {
                "type": "string",
                "minLength": 1
              }
            }
          }
        }
      }
    },
    "image": {
      "type": "string",
      "minLength": 1,
      "maxLength": 255
    },
    "runtime": {
      "type": "object",
      "additionalProperties": false,
      "required": ["workdir", "appPort", "agentPort"],
      "properties": {
        "workdir": {
          "type": "string",
          "pattern": "^/"
        },
        "appPort": {
          "type": "integer",
          "minimum": 1,
          "maximum": 65535
        },
        "agentPort": {
          "type": "integer",
          "minimum": 1,
          "maximum": 65535
        },
        "devPort": {
          "type": "integer",
          "minimum": 1,
          "maximum": 65535
        },
        "startupCommands": {
          "type": "string",
          "minLength": 1
        },
        "restoreCommand": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "resources": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "memory": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "reservationMb": {
              "type": "integer",
              "minimum": 1
            },
            "limitMb": {
              "type": "integer",
              "minimum": 1
            }
          }
        },
        "cpu": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "reservation": {
              "type": "number",
              "minimum": 0.001
            },
            "limit": {
              "type": "number",
              "minimum": 0.001
            }
          }
        }
      }
    },
    "integrations": {
      "type": "object",
      "additionalProperties": {
        "type": "object",
        "additionalProperties": false,
        "required": ["provider", "required", "mode", "scopes"],
        "properties": {
          "provider": {
            "type": "string",
            "enum": ["google"]
          },
          "required": {
            "type": "boolean"
          },
          "mode": {
            "type": "string",
            "enum": ["on_demand"]
          },
          "scopes": {
            "type": "array",
            "minItems": 1,
            "uniqueItems": true,
            "items": {
              "type": "string",
              "minLength": 1
            }
          }
        }
      }
    },
    "services": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "mysql": {
          "type": "object",
          "additionalProperties": false,
          "required": ["required", "database"],
          "properties": {
            "required": {
              "type": "boolean"
            },
            "database": {
              "type": "string",
              "minLength": 1
            }
          }
        },
        "oauth": {
          "type": "object",
          "additionalProperties": false,
          "required": ["required"],
          "properties": {
            "required": {
              "type": "boolean"
            }
          }
        },
        "storage": {
          "type": "object",
          "additionalProperties": false,
          "required": ["required"],
          "properties": {
            "required": {
              "type": "boolean"
            }
          }
        }
      }
    },
    "env": {
      "type": "object",
      "additionalProperties": false,
      "required": ["template"],
      "properties": {
        "template": {
          "type": "object",
          "additionalProperties": {
            "type": "string"
          }
        }
      }
    }
  }
}
